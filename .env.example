# Copy to .env and fill in. Never commit .env.

# Groq (free LLM) — get your key at console.groq.com, no credit card needed
GROQ_API_KEY=gsk_...

# Transcript source: "local" reads from data/transcripts/{TICKER}_{YEAR}_Q{Q}.txt (free)
# Switch to "fmp" only if you have a paid FMP plan
TRANSCRIPT_SOURCE=local
FMP_API_KEY=

# ChromaDB persists to disk — no server or Docker needed
CHROMA_PATH=./data/chroma

# SEC EDGAR requires a descriptive User-Agent (their rule)
SEC_USER_AGENT=your-name your-email@example.com
